# These are all provisioned automatically by Lovable Cloud — no manual .env needed.
# They are shown here for reference only.

# Server-side (never exposed to the browser)
OPENWEATHER_API_KEY=your_openweathermap_api_key
LOVABLE_API_KEY=auto_provisioned_by_lovable_cloud
SUPABASE_URL=auto_provisioned
SUPABASE_PUBLISHABLE_KEY=auto_provisioned
SUPABASE_SERVICE_ROLE_KEY=auto_provisioned

# Browser (safe to expose)
VITE_SUPABASE_URL=auto_provisioned
VITE_SUPABASE_PUBLISHABLE_KEY=auto_provisioned
